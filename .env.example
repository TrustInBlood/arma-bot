# Discord Bot Configuration
# Note: The bot token is stored directly in index.js for this application

# Webhook Server Configuration
SERVER_PORT=your_server_port_here  # Port for the webhook server to listen on
SERVER_IP=your_server_ip_here  # IP address for the webhook server to bind to (0.0.0.0 for all interfaces)

# Note: Make sure to create a .env file with your actual values
# and add .env to your .gitignore file to keep sensitive information private

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CHAT_CHANNEL_ID=your_chat_channel_id_here
GUILD_ID=your_guild_id_here 